<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<TabPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="400.0" prefWidth="600.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.joao.view.ClienteController">
  <tabs>
    <Tab text="Clientes Cadastrados">
         <content>
            <TableView fx:id="tableCadastrados" prefHeight="200.0" prefWidth="200.0">
              <columns>
                <TableColumn fx:id="colNome" prefWidth="75.0" text="Nome" />
                  <TableColumn fx:id="colFiliacao" prefWidth="75.0" text="Filiação" />
                <TableColumn fx:id="colCpf" prefWidth="75.0" text="CPF" />
                  <TableColumn fx:id="colTelefone" prefWidth="75.0" text="Telefone" />
                  <TableColumn fx:id="colEndereco" prefWidth="75.0" text="Endereço" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </content>
    </Tab>
    <Tab text="Cadastrar Novo">
         <content>
            <GridPane>
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="337.0" minWidth="10.0" prefWidth="300.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="318.0" minWidth="10.0" prefWidth="300.0" />
              </columnConstraints>
              <rowConstraints>
                  <RowConstraints maxHeight="44.0" minHeight="0.0" prefHeight="21.0" vgrow="SOMETIMES" />
                  <RowConstraints maxHeight="101.0" minHeight="10.0" prefHeight="37.0" vgrow="SOMETIMES" />
                  <RowConstraints maxHeight="133.0" minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                  <RowConstraints maxHeight="146.0" minHeight="10.0" prefHeight="37.0" vgrow="SOMETIMES" />
                  <RowConstraints maxHeight="170.0" minHeight="10.0" prefHeight="28.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="171.0" minHeight="0.0" prefHeight="34.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="201.0" minHeight="3.0" prefHeight="27.0" vgrow="SOMETIMES" />
                  <RowConstraints maxHeight="275.0" minHeight="10.0" prefHeight="97.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="185.0" minHeight="10.0" prefHeight="45.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Nome *" />
                  <Label text="CPF *" GridPane.rowIndex="2" />
                  <Label text="Telefone *" GridPane.rowIndex="4" />
                  <TextField fx:id="txtNome" GridPane.columnSpan="2" GridPane.rowIndex="1">
                     <cursor>
                        <Cursor fx:constant="TEXT" />
                     </cursor>
                  </TextField>
                  <TextField fx:id="txtCpf" GridPane.rowIndex="3">
                     <cursor>
                        <Cursor fx:constant="TEXT" />
                     </cursor>
                     <GridPane.margin>
                        <Insets right="20.0" />
                     </GridPane.margin>
                  </TextField>
                  <TextField fx:id="txtTelefone" GridPane.rowIndex="5">
                     <cursor>
                        <Cursor fx:constant="TEXT" />
                     </cursor>
                     <GridPane.margin>
                        <Insets right="20.0" />
                     </GridPane.margin>
                  </TextField>
                  <Label text="Endereço" GridPane.rowIndex="6" />
                  <TextArea fx:id="txtEndereco" prefHeight="200.0" prefWidth="454.0" wrapText="true" GridPane.columnSpan="2" GridPane.rowIndex="7">
                     <cursor>
                        <Cursor fx:constant="TEXT" />
                     </cursor>
                  </TextArea>
                  <Label text="Filiação *" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Button fx:id="btnSalvar" mnemonicParsing="false" onAction="#cadastrar" prefHeight="25.0" prefWidth="150.0" text="Salvar" GridPane.halignment="CENTER" GridPane.rowIndex="8" />
                  <Button fx:id="btnLimpar" mnemonicParsing="false" onAction="#handleLimparFormulario" prefHeight="25.0" prefWidth="150.0" text="Limpar Formulário" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="8" />
                  <ComboBox fx:id="comboFiliacao" prefWidth="150.0" promptText="Selecione a Filiação" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </GridPane>
         </content>
    </Tab>
  </tabs>
</TabPane>
